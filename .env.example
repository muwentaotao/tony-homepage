# ============================================================
# 2026 届毕业留言板块 — 环境变量模板
# 复制此文件为 .env.local 并填入真实值（.env.local 已被 gitignore 保护）
# 严禁将真实密钥提交到 Git！
# ============================================================

# Supabase（服务端专用，不要加 VITE_ 前缀）
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# 管理员账号（建议只设一个管理员）
ADMIN_USERNAME=admin
# 使用 bcrypt 生成，示例生成命令：
# node -e "console.log(require('bcryptjs').hashSync('your-password', 10))"
ADMIN_PASSWORD_HASH=

# JWT 签名密钥（请生成两个独立的长随机字符串）
JWT_SECRET_ADMIN=
JWT_SECRET_STUDENT=

# AES-256-GCM 密码加密密钥（用于加密保存四位数学生密码，以便后台导出）
# 请生成 32 字节 base64 编码的密钥，示例：
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
PASSWORD_ENCRYPTION_KEY=
